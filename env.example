IGRILL_PORT=39120
IGRILL_POLL_INTERVAL=15
IGRILL_TIMEOUT=30
IGRILL_MAC_PREFIX=70:91:8F
IGRILL_BIND_ADDRESS=0.0.0.0
IGRILL_SCAN_INTERVAL=60
IGRILL_SCAN_TIMEOUT=5
IGRILL_LOG_LEVEL=INFO
IGRILL_RECONNECT_GRACE=60
IGRILL_DB_PATH=/data/igrill.db
IGRILL_SESSION_TOKEN=
# BLE connection timeout in seconds (separate from read timeout)
IGRILL_CONNECT_TIMEOUT=10
# Maximum backoff delay in seconds for failed BLE connections
IGRILL_MAX_BACKOFF=60
# Per-subsystem log level overrides (empty = use IGRILL_LOG_LEVEL)
IGRILL_LOG_LEVEL_BLE=
IGRILL_LOG_LEVEL_WS=
IGRILL_LOG_LEVEL_SESSION=
IGRILL_LOG_LEVEL_ALERT=
IGRILL_LOG_LEVEL_HTTP=
